# === Git-CI-Gym Configuration ===

# 1. LLM API Configuration (Required for inference.py and ai_repair.py)
# If using OpenAI: https://api.openai.com/v1
# If using Gemini (OpenAI-compatible): https://generativelanguage.googleapis.com/v1beta/openai/
# If using Groq: https://api.groq.com/openai/v1
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
MODEL_NAME=gemini-flash 2.5

# 2. Authentication Tokens
# Your OpenAI, Groq, or Gemini API Key
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Your Hugging Face token (if deploying/testing on HF)
HF_TOKEN=your_huggingface_token_here

# 3. GitHub Integration (New OAuth Feature)
# Create these at GitHub Settings > Developer Settings > OAuth Apps
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Optional: Personal Access Token for manual/unauthenticated testing fallback
GITHUB_TOKEN=your_github_personal_access_token_here

# 4. Server Settings
PORT=7860
PYTHONUNBUFFERED=1
PYTHONPATH=.
